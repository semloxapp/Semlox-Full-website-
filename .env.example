# AWB extraction runs server-side through POST /api/awb/extract.
AWB_EXTRACTION_MODE=mock
AWB_EXTRACTION_API_URL=
AWB_EXTRACTION_TIMEOUT_MS=180000

# Optional server-to-server header when supported by the Flask service.
AWB_EXTRACTION_API_KEY=
# Enables server-side AWB processing and review-time tracking.
AWB_TIMING_TRACKING_ENABLED=false

# Temporarily displays the user-side timing verification panel.
NEXT_PUBLIC_AWB_TIMING_DEBUG_UI=false

# Displays AWB timing analytics on the admin Performance page.
NEXT_PUBLIC_ADMIN_TIMING_ANALYTICS_ENABLED=false

# Recommended staging:
# AWB_TIMING_TRACKING_ENABLED=true
# NEXT_PUBLIC_AWB_TIMING_DEBUG_UI=true
# NEXT_PUBLIC_ADMIN_TIMING_ANALYTICS_ENABLED=true
#
# Recommended production after testing:
# AWB_TIMING_TRACKING_ENABLED=true
# NEXT_PUBLIC_AWB_TIMING_DEBUG_UI=false
# NEXT_PUBLIC_ADMIN_TIMING_ANALYTICS_ENABLED=true
#
# Set all three values to false to disable timing collection and timing UI.
